{
  "Name": "spr-tailscale",
  "ComposeFilePath": "plugins/user/spr-tailscale/docker-compose.yml",
  "UnixPath": "/state/plugins/spr-tailscale/socket",
  "URI": "spr-tailscale",
  "HasUI": true,
  "Icon": "BlocksIcon",
  "HasTopology": true,
  "SandboxedUI": false,
  "InstallTokenPath": "/configs/plugins/spr-tailscale/api-token",
  "ScopedPaths": ["/firewall/config:r", "/firewall/custom_interface:rw"],
  "NetworkCapabilities": {
    "Interface": "spr-tailscale",
    "Policies": ["wan", "dns", "api"],
    "Groups": ["tailnet"]
  },
  "Enabled": true
}
